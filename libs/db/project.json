{
  "name": "@app/db",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/db/src",
  "projectType": "library",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc --noEmit -p libs/db/tsconfig.json" }
    },
    "generate": {
      "executor": "nx:run-commands",
      "options": { "command": "pnpm --filter @app/db exec prisma generate" }
    }
  },
  "tags": ["type:lib", "scope:shared"]
}
