{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@app/db": ["../../libs/db/src/index.ts"],
      "@app/ai": ["../../libs/ai/src/index.ts"],
      "@app/ui": ["../../libs/ui/src/index.ts"],
      "@app/ui/*": ["../../libs/ui/src/*"],
      "@app/ui-tokens": ["../../libs/ui-tokens/src/index.ts"],
      "@app/form": ["../../libs/form/src/index.ts"],
      "@app/shared-types": ["../../libs/shared-types/src/index.ts"]
    }
  },
  "include": ["next-env.d.ts", "src/**/*", ".next/types/**/*.ts"],
  "exclude": ["node_modules", ".next"]
}
