{
  "name": "@app/web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/web/src",
  "projectType": "application",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "pnpm --filter @app/web typecheck" }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "pnpm --filter @app/web build" }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": { "command": "pnpm --filter @app/web dev" }
    }
  },
  "tags": ["type:app", "scope:web"]
}
