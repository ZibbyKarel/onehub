{
  "name": "ig-giveaway-aggregator",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted Instagram giveaway aggregator. Daily scrapes configured IG accounts, classifies posts with Claude, and surfaces contests in a Next.js dashboard.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "nx run-many -t build",
    "lint": "nx run-many -t lint",
    "test": "nx run-many -t test",
    "typecheck": "nx run-many -t typecheck",
    "dev:web": "pnpm --filter @app/web dev",
    "dev:worker": "pnpm --filter @app/worker dev",
    "worker:once": "pnpm --filter @app/worker dev:run-once",
    "prisma": "pnpm --filter @app/db exec prisma",
    "prisma:generate": "pnpm --filter @app/db exec prisma generate",
    "prisma:migrate": "pnpm --filter @app/db exec prisma migrate dev",
    "prisma:studio": "pnpm --filter @app/db exec prisma studio",
    "prisma:deploy": "pnpm --filter @app/db exec prisma migrate deploy",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "postinstall": "pnpm prisma:generate"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "nx": "^20.0.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2"
  }
}
