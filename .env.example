# ----- Database -----
# Inside docker-compose the hostname is "postgres"; outside use "localhost"
DATABASE_URL="postgresql://ig:ig@localhost:5432/ig_giveaways?schema=public"

# ----- Anthropic / Claude -----
ANTHROPIC_API_KEY="sk-ant-..."
# Override model if needed; default is claude-opus-4-7 (see libs/ai/src/config.ts)
# ANTHROPIC_MODEL="claude-opus-4-7"
# Per-request max_tokens (default 4096)
# ANTHROPIC_MAX_TOKENS="4096"

# ----- Instagram credentials -----
# Create a dedicated throwaway IG account; do not use your main profile.
IG_USERNAME="your_ig_handle"
IG_PASSWORD="your_ig_password"

# Path to persistent Playwright session (cookies/localStorage)
# Inside docker this maps to a named volume; locally use .data/ig-session
IG_SESSION_DIR=".data/ig-session"

# ----- Worker schedule -----
# Cron expression for the daily scrape. Default: 06:00 local time.
WORKER_CRON="0 6 * * *"
# Set to "true" to run immediately on boot (useful for dev)
WORKER_RUN_ON_BOOT="false"
# Max posts scraped per handle per run
WORKER_MAX_POSTS_PER_HANDLE="25"
# Seconds between handles (anti rate-limit)
WORKER_HANDLE_DELAY_SECONDS="10"

# ----- Web -----
NEXT_PUBLIC_APP_NAME="IG Giveaway Aggregator"
# Public URL of the dashboard (used for permalinks in emails, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ----- Logging -----
LOG_LEVEL="info"
NODE_ENV="development"
